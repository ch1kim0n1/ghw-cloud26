CAFAI_SERVER_ADDR=:8080
CAFAI_ALLOWED_ORIGINS=http://localhost:5173
CAFAI_WORKER_INTERVAL=5s
CAFAI_SHUTDOWN_TIMEOUT=10s

# Phase 2 and Phase 3 are part of the shipped app and require Azure configuration.
# The server will fail to start until the variables below are set.

AZURE_VIDEO_INDEXER_URL=
AZURE_VIDEO_INDEXER_ACCOUNT_ID=
AZURE_VIDEO_INDEXER_LOCATION=
AZURE_VIDEO_INDEXER_ACCESS_TOKEN=
AZURE_OPENAI_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_ML_URL=
AZURE_BLOB_URL=
AZURE_BLOB_CONTAINER=
AZURE_BLOB_SAS_TOKEN=
AZURE_RENDER_URL=
AZURE_RENDER_API_KEY=

# Optional: override repo-root-relative defaults
# CAFAI_DATABASE_PATH=tmp/cafai_mvp.db
# CAFAI_MIGRATIONS_DIR=backend/scripts/migrations

# Optional / deferred for later phases
# AZURE_SPEECH_URL=
